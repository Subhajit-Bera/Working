{
  "name": "@servanza-services/workers",
  "version": "1.0.0",
  "description": "Background job processors",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "prisma:generate": "npx prisma generate --schema=../../prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate dev --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@servanza-packages/shared": "file:../../servanza-packages/shared",
    "@socket.io/redis-emitter": "^5.1.0",
    "bullmq": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.3.2",
    "nodemailer": "^7.0.12",
    "prisma": "^5.7.0",
    "stripe": "^14.10.0",
    "twilio": "^4.20.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
