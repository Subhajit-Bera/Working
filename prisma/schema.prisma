generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}


enum AssignmentStatus {
  PENDING
  ACCEPTED
  ON_WAY
  ARRIVED
  IN_PROGRESS
  REJECTED
  CANCELLED
  COMPLETED
}

enum AuthProvider {
  GOOGLE
  EMAIL
  PHONE
}

enum BookingStatus {
  PENDING
  QUEUED      // After-hours booking waiting for 9 AM activation
  ASSIGNED
  ACCEPTED
  ON_WAY
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  FAILED
  ESCALATED   // Admin intervention required after max retries
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_ASSIGNED
  BOOKING_ACCEPTED
  BOOKING_STARTED
  BOOKING_COMPLETED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  RATING_RECEIVED
  GENERAL
  // Added for auth
  AUTH_VERIFICATION
  AUTH_PASSWORD_RESET
}

enum PaymentMethod {
  PREPAID
  CASH
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum UserRole {
  USER
  BUDDY
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS_MANAGER
  FINANCE_MANAGER
  SUPPORT_AGENT
}

enum BankDetailsMethod {
  ACCOUNT_DETAILS
  DOCUMENT_UPLOAD
}

model Address {
  id               String   @id @default(cuid())
  userId           String
  label            String   // "Home", "Work", "Other"
  formattedAddress String
  streetAddress    String?
  city             String?
  state            String?
  postalCode       String?
  country          String   @default("IN")
  location         Unsupported("geography(Point, 4326)")?
  latitude         Float
  longitude        Float
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings         Booking[]
  @@index([userId])
  @@index([location], type: Gist) // Gist index for PostGIS
  @@map("addresses")
}

model Assignment {
  id              String           @id @default(cuid())
  bookingId       String
  buddyId         String
  status          AssignmentStatus @default(PENDING)
  estimatedEtaMins Int?
  distanceKm      Float?
  assignedAt      DateTime         @default(now())
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  booking         Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  buddy           Buddy            @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  auditLogs       AuditLog[]
  @@index([bookingId])
  @@index([buddyId])
  @@index([status])
  @@index([assignedAt])
  @@unique([bookingId, buddyId]) // Prevents duplicate assignments, enables idempotent upsert
  @@map("assignments")
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  bookingId    String?
  assignmentId String?
  action       String   // e.g., "BOOKING_CREATED", "ASSIGNMENT_ACCEPTED"
  entity       String   // e.g., "Booking", "Assignment"
  entityId     String
  changes      Json?    // Old and new values
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  booking      Booking?     @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  assignment   Assignment?  @relation(fields: [assignmentId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([bookingId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Booking {
  id              String         @id @default(cuid())
  userId          String
  serviceId       String
  addressId       String
  scheduledStart  DateTime       // When the service should start
  scheduledEnd    DateTime       // When the service should end
  isImmediate     Boolean        @default(false) // If true, ASAP booking
  status          BookingStatus  @default(PENDING)
  paymentMethod   PaymentMethod  @default(PREPAID)
  paymentStatus   PaymentStatus  @default(PENDING)
  price           Float
  taxAmount       Float          @default(0)
  discountAmount  Float          @default(0)
  totalAmount     Float
  currency        String         @default("INR")
  specialInstructions String?
  metadata        Json?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  completionOtp   String?       // OTP for job completion verification
  completionOtpExpiry DateTime? // Expiry time for completion OTP
  
  // Retry & Escalation tracking
  retryCount       Int       @default(0)   // Number of broadcast retry attempts
  lastRetryAt      DateTime?              // Last time a retry was triggered
  escalatedAt      DateTime?              // When escalated to admin
  excludedBuddyIds String[]  @default([]) // Buddies excluded from assignment (rejected after accept)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  service         Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  address         Address        @relation(fields: [addressId], references: [id], onDelete: Restrict)
  assignments     Assignment[]
  otpVerification OtpVerification?
  transactions    Transaction[]
  reviews         Review[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  chatMessages    ChatMessage[]
  callLogs        CallLog[]
  @@index([userId])
  @@index([serviceId])
  @@index([status])
  @@index([scheduledStart])
  @@index([createdAt])
  @@map("bookings")
}


model Buddy {
  id                String            @id // Buddy.id references User.id (one-to-one)
  user              User              @relation(fields: [id], references: [id], onDelete: Cascade)
  bio               String?
  experience        Int?              // Years of experience
  languages         String[]          @default([])
  services          Service[]
  
  // Basic Profile Fields
  dob               String?           // Date of birth
  whatsapp          String?           // WhatsApp number
  secondaryPhone    String?           // Secondary phone number
  bloodGroup        String?           // Blood group
  city              String?
  permanentAddress  String?           // Permanent address
  currentAddress    String?           // Current address
  
  // Progress Tracking Objects (stored as JSON)
  bankDetails       Json?             // { accountNumber, ifscCode, accountHolderName, bankName } OR { bankDocument: url }
  bankDetailsMethod BankDetailsMethod? // Method used: ACCOUNT_DETAILS or DOCUMENT_UPLOAD
  emergencyContact  Json?             // { name, phone, relationship }
  documents         Json?             // { aadhaarFront, aadhaarBack, pan, bankDocument }
  jobStartDate      DateTime?         // Assigned by admin after training completion
  rating            Float             @default(0)
  totalRatings      Int               @default(0)
  totalJobs         Int               @default(0)
  completionRate    Float             @default(0)
  isAvailable       Boolean           @default(false)
  isOnline          Boolean           @default(false)
  maxRadius         Int               @default(10) // km
  lastKnownLocation Unsupported("geography(Point, 4326)")?
  lastLocationTime  DateTime?
  lastLocationLat   Float?
  lastLocationLong  Float?
  workingAreas      Json?             // Array of polygon coordinates
  isVerified        Boolean           @default(false)
  verifiedAt        DateTime?
  documentsJson     Json?             // ID proof, address proof, etc. (legacy field)
  totalEarnings     Float             @default(0)
  
  // Training fields
  trainingStartDate DateTime?         // Training start date selected by buddy (next 3 days from verification)
  trainingDaysTaken Int               @default(0) // Days of training taken (max 5)
  isTrainingCompleted Boolean         @default(false) // Training completion status
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  assignments       Assignment[]
  schedules         BuddySchedule[]
  locationEvents    LocationEvent[]
  reviews           Review[]
  verification      BuddyVerification?
  @@index([lastKnownLocation], type: Gist) // Gist index for PostGIS
  @@map("buddies")
}


model BuddySchedule {
  id          String     @id @default(cuid())
  buddyId     String
  dayOfWeek   DayOfWeek
  startTime   String     // Format: "HH:MM" (e.g., "09:00")
  endTime     String     // Format: "HH:MM" (e.g., "18:00")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  buddy       Buddy      @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  @@index([buddyId])
  @@index([dayOfWeek])
  @@map("buddy_schedules")
}

model BuddyVerification {
  id                    String   @id @default(cuid())
  buddyId               String   @unique
  buddy                 Buddy    @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  
  // Aadhar verification (front and back)
  aadhaarFrontVerified   Boolean  @default(false)
  aadhaarFrontComment   String?
  aadhaarBackVerified    Boolean  @default(false)
  aadhaarBackComment     String?
  
  // PAN verification
  panVerified           Boolean  @default(false)
  panComment            String?
  
  // Bank details verification
  bankDetailsVerified    Boolean  @default(false)
  bankDetailsComment     String?
  
  // Emergency contact verification
  emergencyContactVerified Boolean @default(false)
  emergencyContactComment  String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@map("buddy_verifications")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  slug        String    @unique
  icon        String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]
  @@map("categories")
}

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  @@map("config")
}

model DailyStats {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  totalBookings     Int      @default(0)
  completedBookings Int      @default(0)
  cancelledBookings Int      @default(0)
  totalRevenue      Float    @default(0)
  newUsers          Int      @default(0)
  activeBuddies     Int      @default(0)
  createdAt         DateTime @default(now())
  @@map("daily_stats")
}

model LocationEvent {
  id        String   @id @default(cuid())
  buddyId   String
  location  Unsupported("geography(Point, 4326)")?
  latitude  Float
  longitude Float
  accuracy  Float?   // in meters
  timestamp DateTime @default(now())
  metadata  Json?    // Speed, heading, altitude, etc.
  buddy     Buddy    @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  @@index([buddyId])
  @@index([timestamp])
  @@index([location], type: Gist) // Gist index for PostGIS
  @@map("location_events")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?            // Additional data
  isRead    Boolean          @default(false)
  readAt    DateTime?
  bookingId String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model OtpVerification {
  id          String    @id @default(cuid())
  bookingId   String    @unique
  phone       String
  otpHash     String    // Hashed OTP for security
  otp         String?   // Store plaintext only in dev/test
  expiresAt   DateTime
  isUsed      Boolean   @default(false)
  usedAt      DateTime?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  createdAt   DateTime  @default(now())
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  @@index([bookingId])
  @@index([phone])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model Review {
  id          String   @id @default(cuid())
  bookingId   String   @unique  // One review per booking
  userId      String
  buddyId     String
  serviceId   String
  rating      Int      // 1-5
  comment     String?
  reply       String?  // Admin/buddy reply
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  buddy       Buddy    @relation(fields: [buddyId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([buddyId])
  @@index([serviceId])
  @@map("reviews")
}

model Service {
  id            String    @id @default(cuid())
  categoryId    String
  title         String
  description   Json?
  durationMins  Int       // Estimated duration in minutes
  basePrice     Float
  currency      String    @default("INR")
  imageUrl      String?
  imageUrls     String[]  @default([])
  isActive      Boolean   @default(true)
  averageRating Float     @default(0)
  totalReviews  Int       @default(0)
  metadata      Json?     // Additional service-specific data
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  category      Category  @relation(fields: [categoryId], references: [id])
  bookings      Booking[]
  buddies       Buddy[]
  favorites     Favorite[]
  reviews       Review[]
  @@index([categoryId])
  @@index([isActive])
  @@map("services")
}

model Transaction {
  id                 String        @id @default(cuid())
  bookingId          String
  userId             String
  amount             Float
  currency           String        @default("INR")
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  stripePaymentId    String?       @unique // Kept for reference
  stripePaymentIntent String?
  razorpayOrderId    String?       @unique
  razorpayPaymentId  String?
  metadata           Json?
  failureReason      String?
  refundedAmount     Float?
  refundedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  booking            Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user               User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([stripePaymentId])
  @@index([razorpayOrderId])
  @@map("transactions")
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  phone         String?        @unique
  name          String
  authProvider  AuthProvider   @default(EMAIL)
  firebaseUid   String?        @unique
  passwordHash  String?
  role          UserRole       @default(USER)
  adminRole     AdminRole?     // Only set for ADMIN users
  isActive      Boolean        @default(true)
  emailVerified Boolean        @default(false)
  phoneVerified Boolean        @default(false)
  profileImage  String?
  deviceTokens  String[]       @default([]) // FCM tokens
  metadata      Json?          // Flexible JSON for additional data (e.g., reset tokens)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastLoginAt   DateTime?
  addresses     Address[]
  bookings      Booking[]
  buddy         Buddy?
  reviews       Review[]
  notifications Notification[]
  transactions  Transaction[]
  auditLogs     AuditLog[]
  offlineMessages OfflineMessage[] @relation("OfflineMessages")
  favorites     Favorite[]
  chatMessages  ChatMessage[]  @relation("ChatMessages")
  callerCalls   CallLog[]      @relation("CallerCalls")
  receiverCalls CallLog[]      @relation("ReceiverCalls")
  @@index([email])
  @@index([phone])
  @@index([firebaseUid])
  @@index([role])
  @@map("users")
}


// Offline messages for Socket.IO persistence
// When users are offline, critical messages are stored here for later delivery
model OfflineMessage {
  id        String   @id @default(cuid())
  userId    String
  event     String   // Socket event name (e.g., 'booking:assigned', 'job:assigned')
  data      Json     // Event payload
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  readAt    DateTime?
  
  user      User     @relation("OfflineMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("offline_messages")
}

// Job backup for queue resilience
// Critical jobs are persisted here for recovery when Redis is unavailable
enum JobBackupStatus {
  PENDING     // Waiting to be processed
  PROCESSING  // Being processed
  COMPLETED   // Successfully processed
  FAILED      // Failed after max retries
  RECOVERED   // Recovered and requeued after Redis restart
}

model JobBackup {
  id          String          @id @default(cuid())
  queueName   String          // assignment-queue, notification-queue, etc.
  jobName     String          // Job type (assign-buddy, buddy-assignment, etc.)
  jobData     Json            // Job payload
  priority    Int             @default(10)
  status      JobBackupStatus @default(PENDING)
  attempts    Int             @default(0)
  maxAttempts Int             @default(3)
  error       String?         // Last error message if failed
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  processedAt DateTime?       // When job was completed/failed
  
  @@index([queueName, status])
  @@index([createdAt])
  @@map("job_backups")
}

// Dynamic Role Permissions for RBAC
model RolePermission {
  id         String    @id @default(cuid())
  role       AdminRole // The admin role
  permission String    // Permission string like 'users.view', 'bookings.edit'
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?   // Admin user ID who granted this permission

  @@unique([role, permission])
  @@index([role])
  @@map("role_permissions")
}

// User Favorites / Wishlist
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId]) // User can only favorite a service once
  @@index([userId])
  @@index([serviceId])
  @@map("favorites")
}

// Discount Type Enum
enum DiscountType {
  PERCENTAGE
  FIXED
}

// Coupons
model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  description    String?
  discountType   DiscountType @default(PERCENTAGE)
  discountValue  Float        // e.g., 10 for 10% or 50 for ₹50
  minOrderAmount Float?       // Minimum order to apply coupon
  maxDiscount    Float?       // Cap for percentage discounts
  expiresAt      DateTime
  isActive       Boolean      @default(true)
  usageLimit     Int?         // Max total uses (null = unlimited)
  usedCount      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model Promotion {
  id           String    @id @default(cuid())
  title        String
  subtitle     String?
  imageUrl     String
  ctaLabel     String?   @default("Book Now")
  ctaLink      String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([isActive])
  @@index([displayOrder])
  @@map("promotions")
}

// ─── Chat & Call Models ─────────────────────────────────────────────

enum ChatMessageType {
  TEXT
  IMAGE
  SYSTEM  // "Buddy has arrived", "Call ended", etc.
}

model ChatMessage {
  id         String          @id @default(cuid())
  bookingId  String
  senderId   String          // User.id (works for both customer and buddy)
  content    String
  type       ChatMessageType @default(TEXT)
  mediaUrl   String?         // For IMAGE type messages
  isRead     Boolean         @default(false)
  readAt     DateTime?
  createdAt  DateTime        @default(now())

  booking    Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender     User            @relation("ChatMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  CONNECTED
  ENDED
  MISSED
  REJECTED
}

model CallLog {
  id           String     @id @default(cuid())
  bookingId    String
  callerId     String
  receiverId   String
  type         CallType   @default(VOICE)
  status       CallStatus @default(RINGING)
  startedAt    DateTime?
  endedAt      DateTime?
  durationSecs Int?
  createdAt    DateTime   @default(now())

  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  caller       User       @relation("CallerCalls", fields: [callerId], references: [id])
  receiver     User       @relation("ReceiverCalls", fields: [receiverId], references: [id])

  @@index([bookingId])
  @@index([callerId])
  @@index([receiverId])
  @@map("call_logs")
}
